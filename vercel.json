{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/email-session", "destination": "/api/email-session" },
    { "source": "/api/check-emails", "destination": "/api/check-emails" },
    { "source": "/api/cron", "destination": "/api/cron" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
